// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


// =======================
// ENUMS
// =======================

enum UserGoal {
  WORK
  STUDY
  PROJECTS
  LIFE
}

enum WorkStyle {
  MINIMAL
  BALANCED
  STRUCTURED
}

enum DisciplineLevel {
  LOW
  MEDIUM
  HIGH
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}


// =======================
// USER
// =======================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  username  String?  @unique
  avatar    String?

  // onboarding
  onboardingIntroDone   Boolean   @default(false)
  onboardingDone        Boolean   @default(false)
  onboardingCompletedAt DateTime?

  goal        UserGoal?
  workStyle   WorkStyle?
  discipline  DisciplineLevel?

  // perfil futuro
  bio        String?
  focusLevel Int?

  // relações
  tasks Task[]
  goals Goal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([onboardingDone])
}


// =======================
// TASK
// =======================

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?

  // estado (fonte única de verdade)
  status      TaskStatus @default(TODO)
  completedAt DateTime?

  // prioridade e prazo
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?

  // produtividade (🔥 diferencial real)
  estimatedTime Int?   // minutos
  energyLevel   Int?   // 1-5

  // organização
  order     Int?
  category  String?

  // recorrência (🔥 retenção)
  isRecurring    Boolean @default(false)
  recurrenceRule String? // "daily", "weekly", etc

  // tracking (🔥 analytics futuro)
  startedAt DateTime?

  // sistema
  archivedAt DateTime?
  source     String?

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
}


// =======================
// GOAL
// =======================

model Goal {
  id          String @id @default(cuid())
  title       String
  description String?

  progress Int @default(0) // 0-100

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}