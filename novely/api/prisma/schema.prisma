// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =======================
// ENUMS
// =======================

enum UserGoal {
  WORK
  STUDY
  PROJECTS
  LIFE
}

enum WorkStyle {
  MINIMAL
  BALANCED
  STRUCTURED
}

enum DisciplineLevel {
  LOW
  MEDIUM
  HIGH
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum GoalStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
}

enum GoalPriority {
  LOW
  MEDIUM
  HIGH
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum GoalProgressMode {
  MANUAL
  TASKS
  HYBRID
}

// =======================
// USER
// =======================

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  name     String?
  username String? @unique
  avatar   String?

  onboardingIntroDone   Boolean   @default(false)
  onboardingDone        Boolean   @default(false)
  onboardingCompletedAt DateTime?

  goal       UserGoal?
  workStyle  WorkStyle?
  discipline DisciplineLevel?

  bio        String?
  focusLevel Int?

  tasks Task[]
  goals Goal[]

  // 🔥 STREAK RELATION (1–1)
  streak Streak?

  // 🔥 STREAK HISTORY (1–N)
  streakHistory StreakHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([onboardingDone])
}

enum StreakStatus {
  ACTIVE
  BROKEN
  FROZEN
}

model Streak {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  current Int @default(0)
  best    Int @default(0)

  status StreakStatus @default(ACTIVE)

  lastUpdatedAt   DateTime?
  lastCompletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model StreakHistory {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date DateTime

  progress Int
  status   String

  createdAt DateTime @default(now())

  @@unique([userId, date]) // 🔥 evita duplicar dia
  @@index([userId, date])
}

// =======================
// GOAL
// =======================

model Goal {
  id String @id @default(cuid())

  title       String
  description String?

  status   GoalStatus   @default(ACTIVE)
  priority GoalPriority @default(MEDIUM)

  // =======================
  // PROGRESSO
  // =======================
  progress       Int              @default(0)
  targetProgress Int              @default(100)
  progressMode   GoalProgressMode @default(MANUAL)

  // =======================
  // INTELIGÊNCIA
  // =======================
  score       Int? // 0–100 (performance geral)
  healthScore Int? // qualidade da execução
  riskLevel   RiskLevel?

  // =======================
  // CONTEXTO TEMPORAL
  // =======================
  dueDate          DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  lastCalculatedAt DateTime?

  // =======================
  // CONTEXTO VISUAL
  // =======================
  color    String?
  icon     String?
  category String?

  // =======================
  // MOTIVAÇÃO
  // =======================
  why String?

  // =======================
  // FUTURO (PROJECTS / COLLAB)
  // =======================
  projectId String?

  archivedAt DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([status, userId])
}

// =======================
// TASK
// =======================

model Task {
  id String @id @default(cuid())

  title       String
  description String?

  status   TaskStatus   @default(TODO)
  priority TaskPriority @default(MEDIUM)

  dueDate     DateTime?
  completedAt DateTime?

  // =======================
  // EXECUÇÃO REAL
  // =======================
  estimatedTime Int?
  actualTime    Int?
  focusTime     Int?
  energyLevel   Int?

  // =======================
  // UI / ORGANIZAÇÃO
  // =======================
  position Int?
  category String?

  // =======================
  // RECORRÊNCIA
  // =======================
  isRecurring    Boolean @default(false)
  recurrenceRule String?

  startedAt  DateTime?
  archivedAt DateTime?

  source String?

  // =======================
  // IMPACTO NA META
  // =======================
  weight Int @default(1)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  goalId String?
  goal   Goal?   @relation(fields: [goalId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([goalId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([goalId, status])
}
