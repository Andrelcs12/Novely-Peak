// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =======================
// ENUMS
// =======================

enum UserGoal {
  WORK
  STUDY
  PROJECTS
  LIFE
}

enum WorkStyle {
  MINIMAL
  BALANCED
  STRUCTURED
}

enum DisciplineLevel {
  LOW
  MEDIUM
  HIGH
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum GoalStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
}

enum GoalPriority {
  LOW
  MEDIUM
  HIGH
}


// =======================
// USER
// =======================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  username  String?  @unique
  avatar    String?

  // onboarding
  onboardingIntroDone   Boolean   @default(false)
  onboardingDone        Boolean   @default(false)
  onboardingCompletedAt DateTime?

  goal        UserGoal?
  workStyle   WorkStyle?
  discipline  DisciplineLevel?

  // perfil futuro
  bio        String?
  focusLevel Int?

  // relações
  tasks Task[]
  goals Goal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([onboardingDone])
}


// =======================
// TASK
// =======================

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?

  status      TaskStatus   @default(TODO)
  completedAt DateTime?

  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?

  estimatedTime Int?   // minutos
  energyLevel   Int?   // 1-5

  order     Int?
  category  String?

  isRecurring    Boolean @default(false)
  recurrenceRule String?

  startedAt  DateTime?
  archivedAt DateTime?
  source     String?

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
}


// =======================
// GOAL
// =======================

model Goal {
  id          String @id @default(cuid())
  title       String
  description String?

  // estado
  status      GoalStatus   @default(ACTIVE)
  priority    GoalPriority @default(MEDIUM)

  // progresso (0–100)
  progress    Int @default(0)

  // prazo e conclusão
  dueDate     DateTime?
  completedAt DateTime?

  // personalização visual (🔥 diferencial de engajamento)
  color String? // hex: "#8b5cf6"
  icon  String? // emoji: "🎯"

  // organização
  category String?

  // soft delete
  archivedAt DateTime?

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
}
