
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum GoalStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
}

enum GoalPriority {
  LOW
  MEDIUM
  HIGH
}

enum GoalProgressMode {
  MANUAL
  TASKS
  HYBRID
}

enum HabitFrequencyType {
  FIXED_DAYS
  WEEKLY_COUNT
}

enum LinkType {
  ARTICLE
  VIDEO
  DOCUMENT
  TOOL
  TWITTER
  GITHUB
  OTHER
}

enum EnergyLevel {
  LOW
  MEDIUM
  HIGH
}

// USER


model User {
  id       String  @id @default(cuid())
  email    String  @unique
  name     String?
  username String? @unique
  avatar   String?

  onboardingIntroDone Boolean @default(false)
  timezone String @default("America/Sao_Paulo")
  tasks          Task[]
  goals          Goal[]
  habits         Habit[]
  links          Link[]
  linkCategories LinkCategory[]

  spotify UserSpotify?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([username])
}

model UserSpotify {
  id String @id @default(cuid())

  spotifyId String @unique
  accessToken String
  refreshToken String
  expiresAt DateTime

  userId String @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}




model Goal {
  id          String @id @default(cuid())

  title       String
  description String?

  status       GoalStatus       @default(ACTIVE)
  priority     GoalPriority     @default(MEDIUM)
  progressMode GoalProgressMode @default(TASKS)

  progress Int @default(0)

  targetDate DateTime?


  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model Task {
  id          String @id @default(cuid())

  title       String
  description String?

  status   TaskStatus   @default(TODO)
  priority TaskPriority @default(MEDIUM)

  energyLevel EnergyLevel @default(MEDIUM)

  position Int @default(0)

  //
  // Datas
  //

  dueDate     DateTime?
  completedAt DateTime?

  //
  // Foco & Produtividade
  //

  estimatedTime Int?
  focusTime     Int?

  //
  // Metadata flexível
  //

  links    Json? @default("[]")
  metadata Json?

  //
  // Relacionamentos
  //

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  goalId String?
  goal   Goal? @relation(fields: [goalId], references: [id], onDelete: SetNull)

  subtasks Subtask[]

  //
  // Datas
  //

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([goalId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([position])
}

//
// SUBTASKS
//

model Subtask {
  id String @id @default(cuid())

  title String
  done  Boolean @default(false)

  position Int @default(0)

  //
  // Relacionamentos
  //

  taskId String
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  //
  // Datas
  //

  createdAt DateTime @default(now())

  @@index([taskId])
}

//
// HABITS
//

model Habit {
  id          String @id @default(cuid())

  title       String
  description String?

  //
  // Frequência
  //

  frequencyType HabitFrequencyType @default(FIXED_DAYS)

  // Ex: [1,2,3,4,5]
  frequencyDays Int[] @default([1, 2, 3, 4, 5, 6, 7])

  // Ex: 3x por semana
  weeklyTargetCount Int @default(7)

  //
  // Streak
  //

  currentStreak Int @default(0)
  maxStreak     Int @default(0)

  //
  // Relacionamentos
  //

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  logs HabitLog[]

  //
  // Datas
  //

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

//
// HABIT LOGS
//

model HabitLog {
  id String @id @default(cuid())

  loggedDate DateTime @db.Date

  //
  // Relacionamentos
  //

  habitId String
  habit   Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  //
  // Datas
  //

  createdAt DateTime @default(now())

  @@unique([habitId, loggedDate])

  @@index([habitId])
  @@index([loggedDate])
}

//
// LINK CATEGORIES
//

model LinkCategory {
  id String @id @default(cuid())

  name  String
  color String?

  //
  // Relacionamentos
  //

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  links Link[]

  //
  // Datas
  //

  createdAt DateTime @default(now())

  @@unique([userId, name])

  @@index([userId])
}

//
// LINKS
//

model Link {
  id String @id @default(cuid())

  title       String?
  description String?

  url String

  //
  // Preview
  //

  domain   String?
  favicon  String?
  image    String?

  //
  // Tipo
  //

  type LinkType @default(ARTICLE)

  //
  // IA
  //

  aiSummary String?
  aiTags    String[]

  //
  // Conteúdo
  //

  notes Json? @default("[]")

  readingTime Int?

  //
  // Organização
  //

  isFavorite Boolean @default(false)
  isArchived Boolean @default(false)

  views Int @default(0)

  lastViewedAt DateTime?

  //
  // Relacionamentos
  //

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId String?
  category   LinkCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  //
  // Datas
  //

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([categoryId])
  @@index([type])
  @@index([isFavorite])
  @@index([isArchived])
}

